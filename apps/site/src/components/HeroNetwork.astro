---
// Bindhub "continuity network" — a dependency-free canvas hero visual.
// Inspired by the converging-data-streams effect from the GitHub hero, but
// reframed for Bindhub: your machines (laptop / desktop / server / agent)
// stream file-versions along sync arcs that DRAIN into one folder at the
// center. The folder pulses each time bytes arrive — "already there".
---

<div class="hero-network" aria-hidden="true">
  <canvas></canvas>
</div>

<style>
  .hero-network {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(
        120% 90% at 52% 78%,
        oklch(0.28 0.09 285 / 55%),
        transparent 60%
      ),
      linear-gradient(180deg, oklch(0.16 0.02 285), oklch(0.11 0.02 285));
  }

  .hero-network canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  type Pt = { x: number; y: number }
  type Machine = {
    fx: number
    fy: number
    label: string
    color: string
    glyph: "laptop" | "desktop" | "server" | "agent"
    sign: number
  }
  type Particle = { t: number; speed: number; size: number }

  const machines: Machine[] = [
    { fx: 0.13, fy: 0.36, label: "Laptop", color: "#5fe3c0", glyph: "laptop", sign: -1 },
    { fx: 0.37, fy: 0.16, label: "Desktop", color: "#6aa9ff", glyph: "desktop", sign: -1 },
    { fx: 0.66, fy: 0.16, label: "Server", color: "#f4c25a", glyph: "server", sign: 1 },
    { fx: 0.89, fy: 0.37, label: "Agent", color: "#a78bfa", glyph: "agent", sign: 1 },
  ]
  const FOLDER: Pt = { x: 0.515, y: 0.74 }

  const roots = document.querySelectorAll<HTMLElement>(".hero-network")
  roots.forEach((root) => initNetwork(root))

  function initNetwork(root: HTMLElement) {
    const canvas = root.querySelector("canvas") as HTMLCanvasElement | null
    if (!canvas) return
    const ctx = canvas.getContext("2d")
    if (!ctx) return

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches
    let W = 0
    let H = 0
    let dpr = 1

    // background vertical "data rain" lines (static texture, GitHub vibe)
    const rails = Array.from({ length: 18 }, (_, i) => ({
      x: (i + 0.5) / 18,
      a: 0.03 + Math.abs(Math.sin(i * 1.7)) * 0.05,
    }))

    const arcs = machines.map(() => [] as Particle[])
    const spawnAcc = machines.map(() => Math.random() * 600)
    const rings: { x: number; y: number; r: number; a: number; color: string }[] = []

    function resize() {
      const rect = root.getBoundingClientRect()
      dpr = Math.min(window.devicePixelRatio || 1, 2)
      W = Math.max(1, rect.width)
      H = Math.max(1, rect.height)
      canvas.width = Math.round(W * dpr)
      canvas.height = Math.round(H * dpr)
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
    }
    resize()
    new ResizeObserver(resize).observe(root)

    const ctrl = (m: Pt, f: Pt, sign: number): Pt => {
      const mx = (m.x + f.x) / 2
      const my = (m.y + f.y) / 2
      const dx = f.x - m.x
      const dy = f.y - m.y
      const len = Math.hypot(dx, dy) || 1
      const nx = (-dy / len) * sign
      const ny = (dx / len) * sign
      return { x: mx + nx * 0.16, y: my + ny * 0.16 }
    }
    const bez = (p0: Pt, c: Pt, p1: Pt, t: number): Pt => {
      const u = 1 - t
      return {
        x: u * u * p0.x + 2 * u * t * c.x + t * t * p1.x,
        y: u * u * p0.y + 2 * u * t * c.y + t * t * p1.y,
      }
    }

    function drawGlyph(m: Machine, px: number, py: number, s: number) {
      ctx.save()
      ctx.translate(px, py)
      ctx.strokeStyle = m.color
      ctx.lineWidth = 1.6
      ctx.lineJoin = "round"
      ctx.lineCap = "round"
      const u = s
      if (m.glyph === "laptop") {
        ctx.strokeRect(-u, -u * 0.7, u * 2, u * 1.3)
        ctx.beginPath()
        ctx.moveTo(-u * 1.4, u * 0.75)
        ctx.lineTo(u * 1.4, u * 0.75)
        ctx.stroke()
      } else if (m.glyph === "desktop") {
        ctx.strokeRect(-u, -u, u * 2, u * 1.5)
        ctx.beginPath()
        ctx.moveTo(0, u * 0.5)
        ctx.lineTo(0, u)
        ctx.moveTo(-u * 0.6, u)
        ctx.lineTo(u * 0.6, u)
        ctx.stroke()
      } else if (m.glyph === "server") {
        ctx.strokeRect(-u, -u, u * 2, u * 0.85)
        ctx.strokeRect(-u, u * 0.05, u * 2, u * 0.85)
        ctx.beginPath()
        ctx.moveTo(u * 0.55, -u * 0.6)
        ctx.lineTo(u * 0.55, -u * 0.58)
        ctx.moveTo(u * 0.55, u * 0.45)
        ctx.lineTo(u * 0.55, u * 0.47)
        ctx.stroke()
      } else {
        // agent: spark / diamond
        ctx.beginPath()
        ctx.moveTo(0, -u * 1.2)
        ctx.lineTo(u * 0.85, 0)
        ctx.lineTo(0, u * 1.2)
        ctx.lineTo(-u * 0.85, 0)
        ctx.closePath()
        ctx.stroke()
        ctx.beginPath()
        ctx.arc(0, 0, u * 0.28, 0, Math.PI * 2)
        ctx.fillStyle = m.color
        ctx.fill()
      }
      ctx.restore()
    }

    function drawFolder(x: number, y: number, glow: number) {
      const s = Math.max(18, Math.min(W, H) * 0.062)
      // glow halo
      const g = ctx.createRadialGradient(x, y, 0, x, y, s * 3.2)
      g.addColorStop(0, `rgba(150,130,255,${0.32 + glow * 0.4})`)
      g.addColorStop(1, "rgba(150,130,255,0)")
      ctx.fillStyle = g
      ctx.beginPath()
      ctx.arc(x, y, s * 3.2, 0, Math.PI * 2)
      ctx.fill()

      // echoed box mark (matches the Bindhub logo)
      const r = s * 0.34
      const off = s * 0.42
      rrect(x - off + off * 0.9, y - s * 0.78, s * 1.05, s * 1.05, r)
      ctx.fillStyle = "rgba(167,139,250,0.35)"
      ctx.fill()
      rrect(x - s * 0.62, y - s * 0.28, s * 1.05, s * 1.05, r)
      const fg = ctx.createLinearGradient(x - s, y - s, x + s, y + s)
      fg.addColorStop(0, "#b6a6ff")
      fg.addColorStop(1, "#8b7bf0")
      ctx.fillStyle = fg
      ctx.fill()

      ctx.font = `600 ${Math.round(s * 0.34)}px Inter, system-ui, sans-serif`
      ctx.textAlign = "center"
      ctx.textBaseline = "top"
      ctx.fillStyle = "rgba(255,255,255,0.92)"
      ctx.fillText("Your folder", x, y + s * 1.0)
      ctx.font = `500 ${Math.round(s * 0.26)}px Inter, system-ui, sans-serif`
      ctx.fillStyle = "rgba(180,166,255,0.85)"
      ctx.fillText("continuous", x, y + s * 1.0 + s * 0.42)
    }

    function rrect(x: number, y: number, w: number, h: number, r: number) {
      ctx.beginPath()
      ctx.moveTo(x + r, y)
      ctx.arcTo(x + w, y, x + w, y + h, r)
      ctx.arcTo(x + w, y + h, x, y + h, r)
      ctx.arcTo(x, y + h, x, y, r)
      ctx.arcTo(x, y, x + w, y, r)
      ctx.closePath()
    }

    let last = performance.now()
    let pulse = 0

    function frame(now: number) {
      const dt = Math.min(50, now - last)
      last = now
      ctx.clearRect(0, 0, W, H)

      // background rails
      ctx.lineWidth = 1
      rails.forEach((rl) => {
        ctx.strokeStyle = `rgba(255,255,255,${rl.a})`
        ctx.beginPath()
        ctx.moveTo(rl.x * W, 0)
        ctx.lineTo(rl.x * W, H * 0.62)
        ctx.stroke()
      })

      const fp: Pt = { x: FOLDER.x * W, y: FOLDER.y * H }

      // arcs + particles
      machines.forEach((m, i) => {
        const mp: Pt = { x: m.fx * W, y: m.fy * H }
        const cn = ctrl({ x: m.fx, y: m.fy }, FOLDER, m.sign)
        const cp: Pt = { x: cn.x * W, y: cn.y * H }

        // base arc
        ctx.strokeStyle = "rgba(255,255,255,0.08)"
        ctx.lineWidth = 1
        ctx.beginPath()
        ctx.moveTo(mp.x, mp.y)
        ctx.quadraticCurveTo(cp.x, cp.y, fp.x, fp.y)
        ctx.stroke()

        // spawn particles
        if (!reduce) {
          spawnAcc[i] += dt
          const interval = 520 + i * 130
          while (spawnAcc[i] > interval) {
            spawnAcc[i] -= interval
            arcs[i].push({ t: 0, speed: 0.00016 + Math.random() * 0.00012, size: 1.6 + Math.random() * 1.4 })
          }
        } else if (arcs[i].length === 0) {
          // static: a couple of frozen particles
          arcs[i].push({ t: 0.35, speed: 0, size: 2 })
          arcs[i].push({ t: 0.7, speed: 0, size: 2 })
        }

        for (let k = arcs[i].length - 1; k >= 0; k--) {
          const p = arcs[i][k]
          p.t += p.speed * dt
          if (p.t >= 1) {
            arcs[i].splice(k, 1)
            pulse = 1
            rings.push({ x: fp.x, y: fp.y, r: 6, a: 0.5, color: m.color })
            continue
          }
          const pos = bez(mp, cp, fp, p.t)
          const tail = bez(mp, cp, fp, Math.max(0, p.t - 0.07))
          const grad = ctx.createLinearGradient(tail.x, tail.y, pos.x, pos.y)
          grad.addColorStop(0, "rgba(255,255,255,0)")
          grad.addColorStop(1, m.color)
          ctx.strokeStyle = grad
          ctx.lineWidth = p.size
          ctx.lineCap = "round"
          ctx.beginPath()
          ctx.moveTo(tail.x, tail.y)
          ctx.lineTo(pos.x, pos.y)
          ctx.stroke()

          ctx.fillStyle = m.color
          ctx.beginPath()
          ctx.arc(pos.x, pos.y, p.size * 0.9, 0, Math.PI * 2)
          ctx.fill()
        }

        // machine node
        const ns = Math.max(13, Math.min(W, H) * 0.034)
        rrect(mp.x - ns, mp.y - ns, ns * 2, ns * 2, ns * 0.42)
        ctx.fillStyle = "rgba(255,255,255,0.05)"
        ctx.fill()
        ctx.strokeStyle = "rgba(255,255,255,0.14)"
        ctx.lineWidth = 1
        ctx.stroke()
        drawGlyph(m, mp.x, mp.y, ns * 0.46)
        // status dot
        ctx.fillStyle = m.color
        ctx.beginPath()
        ctx.arc(mp.x + ns * 0.74, mp.y - ns * 0.74, ns * 0.16, 0, Math.PI * 2)
        ctx.fill()
        // label
        ctx.font = `500 ${Math.round(ns * 0.62)}px Inter, system-ui, sans-serif`
        ctx.textAlign = "center"
        ctx.textBaseline = "top"
        ctx.fillStyle = "rgba(255,255,255,0.6)"
        ctx.fillText(m.label, mp.x, mp.y + ns * 1.35)
      })

      // absorb rings
      for (let k = rings.length - 1; k >= 0; k--) {
        const rg = rings[k]
        rg.r += dt * 0.05
        rg.a -= dt * 0.0016
        if (rg.a <= 0) {
          rings.splice(k, 1)
          continue
        }
        ctx.strokeStyle = `rgba(167,139,250,${rg.a})`
        ctx.lineWidth = 1.5
        ctx.beginPath()
        ctx.arc(rg.x, rg.y, rg.r, 0, Math.PI * 2)
        ctx.stroke()
      }

      pulse = Math.max(0, pulse - dt * 0.004)
      drawFolder(fp.x, fp.y, pulse)

      if (!reduce) requestAnimationFrame(frame)
    }

    if (reduce) {
      frame(performance.now())
    } else {
      requestAnimationFrame(frame)
    }
  }
</script>
