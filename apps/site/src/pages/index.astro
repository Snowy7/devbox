---
import SiteShell from "../components/SiteShell.astro"
import HeroOrbit from "../components/HeroOrbit.astro"

const dashboardBaseUrl = (import.meta.env.PUBLIC_BINDHUB_DASHBOARD_URL ?? "").replace(/\/$/, "")
const dashboardUrl = dashboardBaseUrl || "/"
---

<SiteShell
  title="Bindhub"
  description="Bindhub keeps a shared code folder continuous across machines, backed by the Loom sync engine direction."
>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <HeroOrbit />
    <div class="hero-inner">
      <span class="eyebrow">Bindhub · folder continuity</span>
      <h1>Your code folder, already there.</h1>
      <p class="lead">
        Open another machine and the folder you trust is ready — source,
        context, machine state, and the bytes to keep moving.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={dashboardUrl}>
          Open dashboard
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14m-6-6 6 6-6 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <a class="button ghost" href="/docs/">
          Read the alpha docs
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="m9 6 6 6-6 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== SHOWCASE ===================== -->
  <section class="section" style="padding-top:0" id="showcase">
    <div class="container">
      <p class="hero-tagline">One folder, continuous in one place.</p>
      <div class="showcase">
        <div class="window">
          <div class="window-bar">
            <span class="window-dots"
              ><span></span><span></span><span></span></span
            >
            <span class="window-title">~/work/Bindhub</span>
            <span class="window-badge"><span class="dot"></span>Synced · 2s ago</span
            >
          </div>
          <div class="filelist">
            <div class="filerow">
              <span class="ficon"
                ><svg viewBox="0 0 24 24" fill="none"
                  ><path
                    d="M3 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linejoin="round"></path></svg
                ></span>
              <span class="fname">apps/</span>
              <span class="fsize">128 files</span>
              <span class="fstate"
                ><span class="dot local"></span>Fully local</span
              >
            </div>
            <div class="filerow">
              <span class="ficon"
                ><svg viewBox="0 0 24 24" fill="none"
                  ><path
                    d="M3 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linejoin="round"></path></svg
                ></span>
              <span class="fname">node_modules/</span>
              <span class="fsize">2.4 GB</span>
              <span class="fstate"
                ><span class="dot cached"></span>Partial cache</span
              >
            </div>
            <div class="filerow">
              <span class="ficon"
                ><svg viewBox="0 0 24 24" fill="none"
                  ><path
                    d="M14 3v4a1 1 0 0 0 1 1h4M5 3h9l5 5v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linejoin="round"></path></svg
                ></span>
              <span class="fname">.env</span>
              <span class="fsize">1.2 KB</span>
              <span class="fstate"
                ><span
                  class="dot"
                  style="background:var(--cached)"></span>Secret · policy</span
              >
            </div>
            <div class="filerow">
              <span class="ficon"
                ><svg viewBox="0 0 24 24" fill="none"
                  ><path
                    d="M3 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linejoin="round"></path></svg
                ></span>
              <span class="fname">agent-work/</span>
              <span class="fsize">remote</span>
              <span class="fstate"
                ><span class="dot remote"></span>Remote-only</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CAPABILITY STRIP ===================== -->
  <section class="section band capstrip" aria-label="What Bindhub tracks">
    <div class="container">
      <span class="cap-label">One folder, every machine</span>
      <span class="cap-sep"></span>
      <span class="cap-tag">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
          ><path
            d="M4 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"
            stroke="currentColor"
            stroke-width="2"
            stroke-linejoin="round"></path></svg
        >Source & context
      </span>
      <span class="cap-tag">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
          ><rect
            x="3"
            y="4"
            width="18"
            height="12"
            rx="2"
            stroke="currentColor"
            stroke-width="2"></rect><path
            d="M8 20h8"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path></svg
        >Machine state
      </span>
      <span class="cap-tag">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
          ><path
            d="M12 3v18M3 8l9-5 9 5"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path></svg
        >Local bytes
      </span>
      <span class="cap-tag">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
          ><path
            d="M3 12a9 9 0 0 1 15-6.7L21 8M21 12a9 9 0 0 1-15 6.7L3 16"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path></svg
        >Folder revisions
      </span>
    </div>
  </section>

  <!-- ===================== FOLDERS (bento) ===================== -->
  <section class="section" id="continuity">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Shared folders</span>
        <h2>The folder is the product boundary.</h2>
        <p class="lead">
          One repo, many repos, no repo, nested apps, secrets, dependencies,
          generated files, agent work. Bindhub treats that as normal developer
          life instead of asking you to clean it up first.
        </p>
      </div>

      <div class="bento">
        <article class="cell lg">
          <span class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path
                d="M4 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linejoin="round"></path></svg
            >
          </span>
          <h3>Trust messy folders.</h3>
          <p>
            Bindhub keeps your intent centered on folders while the engine
            handles object storage, cache metadata, and future chunk transfer —
            whatever your folder actually contains.
          </p>
          <div class="folder-mock" aria-hidden="true">
            <span class="chip"><span class="dot remote"></span>monorepo/</span>
            <span class="chip"><span class="dot cached"></span>.env</span>
            <span class="chip"><span class="dot local"></span>node_modules/</span>
            <span class="chip"><span class="dot local"></span>build/</span>
            <span class="chip"><span class="dot cached"></span>secrets/</span>
            <span class="chip"><span class="dot remote"></span>agent-work/</span>
          </div>
        </article>

        <article class="cell sm">
          <span class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path
                d="M3 3v5h5M3.05 13A9 9 0 1 0 6 5.3L3 8"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path><path
                d="M12 7.5V12l3.5 2"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </span>
          <h3>Capture file versions often</h3>
          <p>
            Loom records individual file states frequently, then coalesces
            stable folder revisions at sync, restore, checkpoint, and merge
            boundaries.
          </p>
        </article>

        <article class="cell sm">
          <span class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path
                d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16m0 5v-5h5"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </span>
          <h3>Restore a coherent tree</h3>
          <p>
            Folder revisions describe a complete view of the tree without
            turning every edit into a whole-folder snapshot.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================== MACHINES (steps) ===================== -->
  <section class="section band" id="machines">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Machines</span>
        <h2>Move between computers without rebuilding context.</h2>
        <p class="lead">
          Machines are first-class. Each one needs a clear cursor, a known
          hydration state, and a trusted auth boundary before it can materialize
          or update a shared folder.
        </p>
      </div>

      <div class="cards">
        <article class="card">
          <span class="num">1</span>
          <h3>Cursor clarity</h3>
          <p>
            Machine, remote, and materialized-folder cursors explain what each
            side believes is current.
          </p>
        </article>
        <article class="card">
          <span class="num">2</span>
          <h3>Checkpoint intent</h3>
          <p>
            Human labels and pins help you retain meaningful folder revisions
            without managing object internals.
          </p>
        </article>
        <article class="card">
          <span class="num">3</span>
          <h3>Sandbox work</h3>
          <p>
            Humans and agents get isolated parallel workspaces that can merge
            back into a trusted shared folder.
          </p>
        </article>
      </div>

      <div class="section-actions" style="justify-content: center">
        <a class="button primary" href={dashboardUrl}>View app route</a>
        <a class="button secondary" href="/docs/getting-started/">Alpha setup</a>
      </div>
    </div>
  </section>

  <!-- ===================== STORAGE (track) ===================== -->
  <section class="section" id="storage">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Sparse and lazy storage</span>
        <h2>Know which bytes are here before pretending they are.</h2>
        <p class="lead">
          Cache entries record object byte availability separately from file
          versions and folder revisions — so a folder can be present long before
          every byte is local.
        </p>
      </div>

      <div class="track">
        <div class="track-node">
          <span class="node-dot" style="--c: var(--remote)"></span>
          <span class="state">Remote-only</span>
          <p>Metadata is known, but the object bytes are not local yet.</p>
        </div>
        <div class="track-node">
          <span class="node-dot" style="--c: var(--cached)"></span>
          <span class="state">Partial</span>
          <p>Some bytes are available while future chunk transfer fills gaps.</p>
        </div>
        <div class="track-node">
          <span class="node-dot" style="--c: var(--local)"></span>
          <span class="state">Fully local</span>
          <p>The cache can serve the object without remote reads.</p>
        </div>
        <div class="track-node">
          <span class="node-dot" style="--c: var(--foreground)"></span>
          <span class="state">Pinned</span>
          <p>Retention intent keeps important revisions from being pruned.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== PRODUCT & ENGINE ===================== -->
  <section class="section band" id="loom">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Product and engine</span>
        <h2>Bindhub is the product. Loom is the engine.</h2>
      </div>
      <div class="cards">
        <article class="card">
          <span class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path
                d="M21 8 12 3 3 8l9 5 9-5ZM3 8v8l9 5 9-5V8M12 13v8"
                stroke="currentColor"
                stroke-width="2"
                stroke-linejoin="round"></path></svg
            >
          </span>
          <h3>Bindhub is the product</h3>
          <p>
            You think in folders and machines — not protocol details or
            Git-only workflows.
          </p>
        </article>
        <article class="card card-accent">
          <span class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><rect
                x="6"
                y="6"
                width="12"
                height="12"
                rx="2.5"
                stroke="currentColor"
                stroke-width="2"></rect><path
                d="M9 2.5v2.5M15 2.5v2.5M9 19v2.5M15 19v2.5M2.5 9H5m-2.5 6H5m14-6h2.5m-2.5 6h2.5"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path></svg
            >
          </span>
          <h3>Loom is the engine direction</h3>
          <p>
            The deeper sync and source-control model underneath: objects, file
            versions, revisions, cursors, and cache records.
          </p>
        </article>
        <article class="card">
          <span class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path
                d="M6 3v12m12-9a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm0 0c0 6-6 4-6 9M6 3a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm0 12a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </span>
          <h3>Git still matters</h3>
          <p>
            Bindhub respects today's repos, but it is not built around Git as the
            only shape a folder can take.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================== TRUST ===================== -->
  <section class="section" id="trust">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Trust and safety</span>
        <h2>Continuity is only useful when the boundary is clear.</h2>
        <p class="lead">
          Bindhub needs plain behavior around secrets, generated files,
          authentication, and what is safe to hydrate on a new machine.
        </p>
      </div>
      <div class="cards">
        <article class="card">
          <span class="check">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path
                d="m5 13 4 4 10-10"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </span>
          <h3>Secrets deserve policy</h3>
          <p>
            Secret detection and block policies should stop unsafe captures
            before object writes.
          </p>
        </article>
        <article class="card">
          <span class="check">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path
                d="m5 13 4 4 10-10"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </span>
          <h3>Auth stays server-owned</h3>
          <p>
            Browser code never passes WorkOS access tokens directly to the
            hosted Bindhub API.
          </p>
        </article>
        <article class="card">
          <span class="check">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path
                d="m5 13 4 4 10-10"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </span>
          <h3>Generated files need intent</h3>
          <p>
            Dependencies, caches, build output, and local overlays are useful,
            but they shouldn't blur the trusted source boundary.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="section" id="agents">
    <div class="container">
      <div class="cta-panel">
        <div class="cta-copy">
          <span class="eyebrow">Developers and agents</span>
          <h2>Get your folder continuous.</h2>
          <p>
            Bindhub is heading toward sandboxes for human and agent work, with
            merge points that make folder state, overlays, and machine identity
            explicit. Request alpha access and tell us the folder you want
            continuous.
          </p>
        </div>
        <form class="contact-form" aria-label="Alpha waitlist form">
          <div class="field">
            <label for="email">Work email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@company.com"
            />
          </div>
          <div class="field">
            <label for="folder">What folder should Bindhub help with?</label>
            <textarea
              id="folder"
              name="folder"
              placeholder="e.g. our monorepo + agent sandboxes"></textarea>
          </div>
          <button class="button primary" type="button">
            Request alpha access
          </button>
          <p class="form-note">
            UI only in this PR — wire to an API or CRM before collecting
            submissions.
          </p>
        </form>
      </div>
    </div>
  </section>
</SiteShell>
