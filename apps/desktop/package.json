{
  "name": "@bindhub/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Bindhub private-alpha Electron control surface.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start": "pnpm build && electron .",
    "start:built": "electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "build": "pnpm typecheck && vite build && tsc -p tsconfig.main.json",
    "test:safety": "node scripts/safety-scan.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.4.1",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  }
}
