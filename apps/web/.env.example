WORKOS_CLIENT_ID=client_replace_me
WORKOS_API_KEY=sk_test_replace_me
WORKOS_COOKIE_PASSWORD=replace-with-32-plus-character-secret
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
WORKOS_SIGN_OUT_REDIRECT_URI=http://localhost:3000/
VITE_BINDHUB_DOCS_URL=http://localhost:3002/docs

# hosted-workos | local-dev-api | local-dev-fixtures
BINDHUB_DASHBOARD_DATA_MODE=local-dev-fixtures
BINDHUB_HOSTED_API_URL=
BINDHUB_HOSTED_API_SERVICE_TOKEN=
BINDHUB_LOCAL_API_URL=http://127.0.0.1:3001
BINDHUB_LOCAL_API_SESSION_TOKEN=
BINDHUB_LOCAL_API_DEVICE_ID=

# Explicit CI/local-only bypass for /auth/cli when WorkOS cannot run.
# Production must leave this unset and use WorkOS/AuthKit.
BINDHUB_LOCAL_DEV_CLI_AUTH=
BINDHUB_LOCAL_DEV_AUTH_EMAIL=local-dev@example.test

# API-side local dev-session helper gate. Keep unset in production.
BINDHUB_API_ENABLE_LOCAL_DEV_SESSION=
BINDHUB_ALLOW_NON_LOOPBACK_LOCAL_DEV_LOGIN=
