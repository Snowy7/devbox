# Local bindhub-api process env.
#
# bindhub-api does not read .env files by itself. Use
# scripts/bindhub-api-local.ps1 to load bindhub/.env.local before starting it.

BINDHUB_API_BIND=127.0.0.1:3001
BINDHUB_API_ROOT=.bindhub-api
BINDHUB_API_METADATA_MODE=memory
BINDHUB_API_SERVICE_TOKEN=

# Enable only when testing bindhub login --local-dev-direct locally.
# Browser CLI auth does not need this helper.
BINDHUB_API_ENABLE_LOCAL_DEV_SESSION=

# Set DATABASE_URL or BINDHUB_API_DATABASE_URL instead of memory mode when using
# a real metadata database.
BINDHUB_API_DATABASE_URL=

# Optional object/blob storage. Leave empty for local filesystem pack storage.
BINDHUB_R2_ENDPOINT=
BINDHUB_R2_BUCKET=
BINDHUB_R2_ACCESS_KEY_ID=
BINDHUB_R2_SECRET_ACCESS_KEY=
BINDHUB_R2_REGION=auto
BINDHUB_R2_PREFIX=
BINDHUB_R2_SESSION_TOKEN=
