# Devbox hosted API deploy env. These belong on the API server, not user machines.
DATABASE_URL=postgres://devbox:devbox@localhost:5432/devbox_metadata
DEVBOX_R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
DEVBOX_R2_BUCKET=devbox-alpha
DEVBOX_R2_ACCESS_KEY_ID=replace-me
DEVBOX_R2_SECRET_ACCESS_KEY=replace-me
# Optional server-side R2/session settings.
# DEVBOX_R2_REGION=auto
# DEVBOX_R2_SESSION_TOKEN=replace-me
DEVBOX_ALLOW_MOCK_AUTH=false

# Optional local/dev server-side object store for hosted transfer without R2.
DEVBOX_OBJECT_LOCAL_ROOT=./hosted-object-store

# Devbox CLI local/dev overrides. Packaged CLIs should bake in the production
# API endpoint; users should not configure Cloudflare/R2 details.
# DEVBOX_API_URL=http://127.0.0.1:8787
DEVBOX_CONFIG_DIR=.devbox

# Low-level alpha smoke helpers. Product CLI users should not need these.
DEVBOX_METADATA_API=http://127.0.0.1:8787
DEVBOX_METADATA_PROJECT=project-example
DEVBOX_ALPHA_INVITE_CODE=replace-after-invite-create
DEVBOX_SESSION_TOKEN=replace-after-hosted-login
DEVBOX_LIVE_DB=./devbox.sqlite3
DEVBOX_LIVE_CACHE=./.devbox-cache
DEVBOX_LIVE_PROJECT_ROOT=./project
DEVBOX_LIVE_TARGET=./receiver-project
DEVBOX_LIVE_MODE=push
DEVBOX_LIVE_ONCE=true
DEVBOX_LIVE_APPLY=false
DEVBOX_REMOTE_KIND=local
DEVBOX_REMOTE_DIR=./remote
DEVBOX_RECEIVER_DB=./receiver.sqlite3
DEVBOX_ALPHA_EVIDENCE_DIR=./.devbox-alpha-evidence
