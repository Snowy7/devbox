# Bindhub hosted API deploy env. These belong on the API server, not user machines.
DATABASE_URL=postgres://bindhub:bindhub@localhost:5432/bindhub_metadata
BINDHUB_R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
BINDHUB_R2_BUCKET=bindhub-alpha
BINDHUB_R2_ACCESS_KEY_ID=replace-me
BINDHUB_R2_SECRET_ACCESS_KEY=replace-me
# Optional server-side R2/session settings.
# BINDHUB_R2_REGION=auto
# BINDHUB_R2_SESSION_TOKEN=replace-me
BINDHUB_ALLOW_MOCK_AUTH=false

# Optional local/dev server-side object store for hosted transfer without R2.
BINDHUB_OBJECT_LOCAL_ROOT=./hosted-object-store

# Bindhub CLI local/dev overrides. Packaged CLIs should bake in the production
# API endpoint; users should not configure Cloudflare/R2 details.
# BINDHUB_API_URL=http://127.0.0.1:8787
BINDHUB_CONFIG_DIR=.bindhub

# Low-level alpha smoke helpers. Product CLI users should not need these.
BINDHUB_METADATA_API=http://127.0.0.1:8787
BINDHUB_METADATA_PROJECT=project-example
BINDHUB_ALPHA_INVITE_CODE=replace-after-invite-create
BINDHUB_SESSION_TOKEN=replace-after-hosted-login
BINDHUB_LIVE_DB=./bindhub.sqlite3
BINDHUB_LIVE_CACHE=./.bindhub-cache
BINDHUB_LIVE_PROJECT_ROOT=./project
BINDHUB_LIVE_TARGET=./receiver-project
BINDHUB_LIVE_MODE=push
BINDHUB_LIVE_ONCE=true
BINDHUB_LIVE_APPLY=false
BINDHUB_REMOTE_KIND=local
BINDHUB_REMOTE_DIR=./remote
BINDHUB_RECEIVER_DB=./receiver.sqlite3
BINDHUB_ALPHA_EVIDENCE_DIR=./.bindhub-alpha-evidence
