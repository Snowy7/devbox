#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/mvp-two-device-smoke

Runs a deterministic local MVP smoke test that proves:
  - Loom local-only capture/checkpoint works
  - Loom local remote sync/clone works
  - Loom sparse clone, hydrate, evict, pin, and cache status work
  - Devbox hosted share/clone works through a local devbox-api
  - Devbox hosted metadata/object split rejects object hash mismatches
  - Git metadata and generated dependencies are not materialized
  - Plain and nested folders materialize
  - Divergent sync refuses safely
  - Secret-looking files are blocked and not uploaded

Environment:
  LOOM_BIN                 Optional path to a built loom binary.
  DEVBOX_BIN               Optional path to a built devbox binary.
  DEVBOX_API_BIN           Optional path to a built devbox-api binary.
  DEVBOX_MVP_SMOKE_DIR     Optional working directory to reuse.
  DEVBOX_CLEAN_SMOKE_DIR   Set true to remove the generated temp directory after a pass.
USAGE
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ -n "${DEVBOX_MVP_SMOKE_DIR:-}" ]]; then
  workdir="$DEVBOX_MVP_SMOKE_DIR"
  mkdir -p "$workdir"
  cleanup=false
else
  workdir="$(mktemp -d "${TMPDIR:-/tmp}/devbox-mvp-smoke.XXXXXX")"
  cleanup=false
fi

if [[ "${DEVBOX_CLEAN_SMOKE_DIR:-false}" == "true" ]]; then
  cleanup=true
fi

evidence_dir="$workdir/evidence"
mkdir -p "$evidence_dir"

api_pid=""

cleanup_all() {
  local status=$?
  if [[ -n "$api_pid" ]] && kill -0 "$api_pid" 2>/dev/null; then
    kill "$api_pid" 2>/dev/null || true
    wait "$api_pid" 2>/dev/null || true
  fi
  if [[ "$cleanup" == "true" ]]; then
    rm -rf "$workdir"
  elif [[ $status -ne 0 ]]; then
    echo "workdir=$workdir" >&2
  fi
}
trap cleanup_all EXIT

fail() {
  echo "[FAIL] $*" >&2
  echo "evidence=$evidence_dir" >&2
  exit 1
}

redact_log() {
  sed -E \
    -e "s/devbox-local-session-[A-Za-z0-9]+/devbox-local-session-<redacted>/g" \
    -e "s/devbox:\/\/[^[:space:]]+/devbox:\/\/<redacted>/g" \
    -e "s/sk-[A-Za-z0-9_.-]+/sk-<redacted>/g" \
    -e "s/github_pat_[A-Za-z0-9_]+/github_pat_<redacted>/g" \
    -e "s/ghp_[A-Za-z0-9_]+/ghp_<redacted>/g"
}

record() {
  local name="$1"
  shift
  local stdout_file="$evidence_dir/$name.stdout.log"
  local stderr_file="$evidence_dir/$name.stderr.log"
  echo "[RUN] $name"
  if "$@" >"$stdout_file.raw" 2>"$stderr_file.raw"; then
    redact_log <"$stdout_file.raw" >"$stdout_file"
    redact_log <"$stderr_file.raw" >"$stderr_file"
    rm -f "$stdout_file.raw" "$stderr_file.raw"
    echo "[PASS] $name"
  else
    local code=$?
    redact_log <"$stdout_file.raw" >"$stdout_file"
    redact_log <"$stderr_file.raw" >"$stderr_file"
    rm -f "$stdout_file.raw" "$stderr_file.raw"
    echo "[FAIL] $name exited $code" >&2
    tail -n 40 "$stderr_file" >&2 || true
    echo "stdout=$stdout_file" >&2
    echo "stderr=$stderr_file" >&2
    exit "$code"
  fi
}

record_expect_failure() {
  local name="$1"
  shift
  local stdout_file="$evidence_dir/$name.stdout.log"
  local stderr_file="$evidence_dir/$name.stderr.log"
  echo "[RUN] $name (expecting refusal)"
  if "$@" >"$stdout_file.raw" 2>"$stderr_file.raw"; then
    redact_log <"$stdout_file.raw" >"$stdout_file"
    redact_log <"$stderr_file.raw" >"$stderr_file"
    rm -f "$stdout_file.raw" "$stderr_file.raw"
    fail "$name unexpectedly succeeded"
  fi
  redact_log <"$stdout_file.raw" >"$stdout_file"
  redact_log <"$stderr_file.raw" >"$stderr_file"
  rm -f "$stdout_file.raw" "$stderr_file.raw"
  echo "[PASS] $name refused safely"
}

record_expected_http_refusal() {
  local name="$1"
  shift
  local stdout_file="$evidence_dir/$name.stdout.log"
  local stderr_file="$evidence_dir/$name.stderr.log"
  echo "[RUN] $name (expecting HTTP refusal)"
  if "$@" >"$stdout_file.raw" 2>"$stderr_file.raw"; then
    redact_log <"$stdout_file.raw" >"$stdout_file"
    redact_log <"$stderr_file.raw" >"$stderr_file"
    rm -f "$stdout_file.raw" "$stderr_file.raw"
    echo "[PASS] $name refused safely"
  else
    local code=$?
    redact_log <"$stdout_file.raw" >"$stdout_file"
    redact_log <"$stderr_file.raw" >"$stderr_file"
    rm -f "$stdout_file.raw" "$stderr_file.raw"
    echo "[FAIL] $name exited $code" >&2
    tail -n 40 "$stderr_file" >&2 || true
    echo "stdout=$stdout_file" >&2
    echo "stderr=$stderr_file" >&2
    exit "$code"
  fi
}

expect_contains() {
  local path="$1"
  local needle="$2"
  grep -Fq "$needle" "$path" || fail "$path did not contain '$needle'"
}

expect_file_text() {
  local path="$1"
  local expected="$2"
  [[ -f "$path" ]] || fail "missing file $path"
  [[ "$(cat "$path")" == "$expected" ]] || fail "unexpected contents in $path"
}

expect_absent() {
  local path="$1"
  [[ ! -e "$path" ]] || fail "unexpected path exists: $path"
}

hosted_object_hash_mismatch_probe() {
  local api_url="$1"
  local folder_id="$2"
  local object_id="$3"
  local session_token="$4"
  local device_id="$5"

  command -v curl >/dev/null 2>&1 || fail "curl is required for hosted object mismatch evidence"
  local body_file="$evidence_dir/hosted-object-hash-mismatch.body.tmp"
  local status
  status="$(curl -sS -o "$body_file" -w '%{http_code}' \
    -X PUT "$api_url/v1/loom/shared-folders/$folder_id/objects/$object_id" \
    -H "authorization: Bearer $session_token" \
    -H "x-devbox-device-id: $device_id" \
    -H "content-type: application/octet-stream" \
    --data-binary 'wrong hosted smoke bytes')"
  echo "http_status=$status"
  cat "$body_file"
  rm -f "$body_file"
  [[ "$status" == "400" ]] || return 1
}

path_for_bin() {
  local env_value="$1"
  local package="$2"
  local binary="$3"
  if [[ -n "$env_value" ]]; then
    printf '%s\n' "$env_value"
    return
  fi

  local suffix=""
  if [[ "${OS:-}" == "Windows_NT" ]]; then
    suffix=".exe"
  fi
  local candidate="$repo_root/target/debug/${binary}${suffix}"
  if [[ ! -x "$candidate" ]]; then
    (cd "$repo_root" && cargo build --quiet -p "$package")
  fi
  printf '%s\n' "$candidate"
}

loom_bin="$(path_for_bin "${LOOM_BIN:-}" loom-cli loom)"
devbox_bin="$(path_for_bin "${DEVBOX_BIN:-}" devbox-cli devbox)"
devbox_api_bin="$(path_for_bin "${DEVBOX_API_BIN:-}" devbox-api devbox-api)"

echo "Devbox MVP two-device smoke"
echo "workdir=$workdir"
echo "evidence=$evidence_dir"

engine_source="$workdir/engine-source"
engine_remote="$workdir/engine-remote"
engine_clone="$workdir/engine-clone"
engine_sparse_clone="$workdir/engine-sparse-clone"
plain_source="$workdir/plain-source"
plain_remote="$workdir/plain-remote"
plain_clone="$workdir/plain-clone"
secret_source="$workdir/secret-source"
secret_remote="$workdir/secret-remote"
conflict_source="$workdir/conflict-source"
conflict_remote="$workdir/conflict-remote"

mkdir -p \
  "$engine_source/apps/api" \
  "$engine_source/apps/web/src" \
  "$engine_source/.git" \
  "$engine_source/node_modules/pkg" \
  "$engine_source/apps/web/dist" \
  "$plain_source/nested/docs" \
  "$secret_source" \
  "$conflict_source"

printf 'engine source\n' > "$engine_source/README.md"
printf 'api\n' > "$engine_source/apps/api/app.txt"
printf 'web\n' > "$engine_source/apps/web/src/index.ts"
printf '[core]\nrepositoryformatversion = 0\n' > "$engine_source/.git/config"
printf 'ref: refs/heads/main\n' > "$engine_source/.git/HEAD"
printf 'generated\n' > "$engine_source/node_modules/pkg/index.js"
printf 'bundle\n' > "$engine_source/apps/web/dist/app.js"
printf 'plain folder\n' > "$plain_source/README.md"
printf 'nested plain folder\n' > "$plain_source/nested/docs/guide.md"
printf 'safe\n' > "$secret_source/README.md"
raw_secret="sk-abcdefghijklmnopqrstuvwxyzABCDEFGH123456"
printf 'OPENAI_API_KEY=%s\n' "$raw_secret" > "$secret_source/secrets.env"
printf 'one\n' > "$conflict_source/README.md"

record "01-loom-local-track" "$loom_bin" track "$engine_source"
expect_contains "$evidence_dir/01-loom-local-track.stdout.log" "Initialized Loom tracking"
expect_contains "$evidence_dir/01-loom-local-track.stdout.log" "Policy:"
record "02-loom-local-checkpoint" "$loom_bin" checkpoint "$engine_source" -m "MVP baseline"
printf 'engine source v2\n' > "$engine_source/README.md"
record "03-loom-local-status-after-edit" "$loom_bin" status "$engine_source"
expect_contains "$evidence_dir/03-loom-local-status-after-edit.stdout.log" "Captured new folder revision"

record "04-loom-remote-add" "$loom_bin" remote add local "$engine_remote" "$engine_source"
record "05-loom-remote-sync" "$loom_bin" sync "$engine_source"
record "06-loom-remote-clone" "$loom_bin" clone "$engine_remote" "$engine_clone"
expect_file_text "$engine_clone/README.md" "engine source v2"
expect_file_text "$engine_clone/apps/api/app.txt" "api"
expect_file_text "$engine_clone/apps/web/src/index.ts" "web"
expect_absent "$engine_clone/.git"
expect_absent "$engine_clone/node_modules"
expect_absent "$engine_clone/apps/web/dist"
record "06a-loom-sparse-clone" "$loom_bin" clone "$engine_remote" "$engine_sparse_clone" --sparse
expect_contains "$evidence_dir/06a-loom-sparse-clone.stdout.log" "Mode: sparse metadata-only"
expect_contains "$evidence_dir/06a-loom-sparse-clone.stdout.log" "Imported objects: 0"
expect_absent "$engine_sparse_clone/README.md"
record "06b-loom-sparse-cache-status" "$loom_bin" cache status "$engine_sparse_clone"
expect_contains "$evidence_dir/06b-loom-sparse-cache-status.stdout.log" "remote-only: 3"
record "06c-loom-sparse-hydrate-readme" "$loom_bin" hydrate "$engine_sparse_clone/README.md"
expect_contains "$evidence_dir/06c-loom-sparse-hydrate-readme.stdout.log" "Fetched objects: 1"
expect_file_text "$engine_sparse_clone/README.md" "engine source v2"
record "06d-loom-sparse-cache-after-hydrate" "$loom_bin" cache status "$engine_sparse_clone"
expect_contains "$evidence_dir/06d-loom-sparse-cache-after-hydrate.stdout.log" "hydrated: 1"
record "06e-loom-sparse-evict-readme" "$loom_bin" evict "$engine_sparse_clone/README.md"
expect_contains "$evidence_dir/06e-loom-sparse-evict-readme.stdout.log" "Removed: 1 files, 1 objects"
expect_absent "$engine_sparse_clone/README.md"
record "06f-loom-sparse-hydrate-api" "$loom_bin" hydrate "$engine_sparse_clone/apps/api/app.txt"
expect_file_text "$engine_sparse_clone/apps/api/app.txt" "api"
record "06g-loom-sparse-pin-api" "$loom_bin" pin "$engine_sparse_clone/apps/api/app.txt"
record "06h-loom-sparse-cache-after-pin" "$loom_bin" cache status "$engine_sparse_clone"
expect_contains "$evidence_dir/06h-loom-sparse-cache-after-pin.stdout.log" "pinned: 1 files"
record_expect_failure "06i-loom-sparse-pinned-evict-refusal" "$loom_bin" evict "$engine_sparse_clone/apps/api/app.txt"
expect_contains "$evidence_dir/06i-loom-sparse-pinned-evict-refusal.stderr.log" "path is pinned"

record "07-plain-track" "$loom_bin" track "$plain_source"
record "08-plain-remote-add" "$loom_bin" remote add local "$plain_remote" "$plain_source"
record "09-plain-sync" "$loom_bin" sync "$plain_source"
record "10-plain-clone" "$loom_bin" clone "$plain_remote" "$plain_clone"
expect_file_text "$plain_clone/README.md" "plain folder"
expect_file_text "$plain_clone/nested/docs/guide.md" "nested plain folder"

record "11-secret-track" "$loom_bin" track "$secret_source"
expect_contains "$evidence_dir/11-secret-track.stdout.log" "secret-blocked"
record "12-secret-remote-add" "$loom_bin" remote add local "$secret_remote" "$secret_source"
record_expect_failure "13-secret-sync-refusal" "$loom_bin" sync "$secret_source"
expect_contains "$evidence_dir/13-secret-sync-refusal.stderr.log" "secret-blocked"
if grep -R -F "$raw_secret" "$secret_remote" "$secret_source/.loom/objects" >/dev/null 2>&1; then
  fail "raw secret was written to a remote or Loom object cache"
fi

record "14-conflict-track" "$loom_bin" track "$conflict_source"
record "15-conflict-remote-add" "$loom_bin" remote add local "$conflict_remote" "$conflict_source"
mkdir -p "$conflict_remote/cursors"
printf 'folder-revision-b3-divergent\n' > "$conflict_remote/cursors/shared-folder.txt"
record_expect_failure "16-conflict-sync-refusal" "$loom_bin" sync "$conflict_source"
expect_contains "$evidence_dir/16-conflict-sync-refusal.stderr.log" "diverged"

api_root="$workdir/api-root"
api_log="$evidence_dir/17-devbox-api.log"
DEVBOX_API_METADATA_MODE=memory "$devbox_api_bin" --root "$api_root" --bind 127.0.0.1:0 >"$api_log.raw" 2>&1 &
api_pid=$!
api_url=""
for _ in $(seq 1 100); do
  if ! kill -0 "$api_pid" 2>/dev/null; then
    redact_log <"$api_log.raw" >"$api_log"
    fail "devbox-api exited before it was ready"
  fi
  api_url="$(grep -Eo 'http://127\.0\.0\.1:[0-9]+' "$api_log.raw" | head -n 1 || true)"
  if [[ -n "$api_url" ]]; then
    break
  fi
  sleep 0.05
done
redact_log <"$api_log.raw" >"$api_log"
[[ -n "$api_url" ]] || fail "could not parse devbox-api URL"
echo "[PASS] 17-devbox-api-start"

product_source="$workdir/product-source"
product_target="$workdir/product-target"
source_config="$workdir/source-config"
target_config="$workdir/target-config"
mkdir -p "$product_source/app" "$product_source/.git" "$product_source/node_modules/pkg"
printf 'product source\n' > "$product_source/README.md"
printf 'nested product file\n' > "$product_source/app/main.txt"
printf '[core]\nrepositoryformatversion = 0\n' > "$product_source/.git/config"
printf 'generated\n' > "$product_source/node_modules/pkg/index.js"

record "18-devbox-source-login" env DEVBOX_CONFIG_DIR="$source_config" "$devbox_bin" login --api "$api_url" --account mvp --device-name "MVP desktop"
record "19-devbox-source-share" env DEVBOX_CONFIG_DIR="$source_config" "$devbox_bin" share "$product_source" --no-background-sync
record "20-devbox-target-login" env DEVBOX_CONFIG_DIR="$target_config" "$devbox_bin" login --api "$api_url" --account mvp --device-name "MVP laptop"
record "21-devbox-target-clone" env DEVBOX_CONFIG_DIR="$target_config" "$devbox_bin" clone product-source "$product_target" --no-background-sync
expect_file_text "$product_target/README.md" "product source"
expect_file_text "$product_target/app/main.txt" "nested product file"
expect_absent "$product_target/.git"
expect_absent "$product_target/node_modules"
product_folder_id="$(awk -F'\t' '$1 == "id" { print $2 }' "$product_source/.loom/metadata/shared_folder.tsv")"
product_object_id="$(awk -F'\t' 'NF > 0 { print $1; exit }' "$product_source/.loom/metadata/cache_entries.tsv")"
product_session_token="$(sed -nE 's/.*"session_token": "([^"]+)".*/\1/p' "$source_config/config.json" | head -n 1)"
product_device_id="$(sed -nE 's/.*"device_id": "([^"]+)".*/\1/p' "$source_config/config.json" | head -n 1)"
[[ -n "$product_folder_id" ]] || fail "could not read hosted shared folder id"
[[ -n "$product_object_id" ]] || fail "could not read hosted object id"
[[ -n "$product_session_token" ]] || fail "could not read hosted session token"
[[ -n "$product_device_id" ]] || fail "could not read hosted device id"
record_expected_http_refusal "21a-devbox-hosted-object-hash-mismatch" hosted_object_hash_mismatch_probe "$api_url" "$product_folder_id" "$product_object_id" "$product_session_token" "$product_device_id"
expect_contains "$evidence_dir/21a-devbox-hosted-object-hash-mismatch.stdout.log" "http_status=400"
expect_contains "$evidence_dir/21a-devbox-hosted-object-hash-mismatch.stdout.log" "object bytes do not match object id"

printf 'product source after edit\n' > "$product_source/README.md"
record "22-devbox-source-push-edit" env DEVBOX_CONFIG_DIR="$source_config" "$devbox_bin" resume "$product_source" --no-background-sync
record "23-devbox-target-sync-edit" env DEVBOX_CONFIG_DIR="$target_config" "$devbox_bin" sync run-loop "$product_target" --max-cycles 1
expect_file_text "$product_target/README.md" "product source after edit"

record "24-devbox-status" env DEVBOX_CONFIG_DIR="$target_config" "$devbox_bin" status
expect_contains "$evidence_dir/24-devbox-status.stdout.log" "Logged in: yes"
expect_contains "$evidence_dir/24-devbox-status.stdout.log" "Shared folders:"

if grep -R -F "$raw_secret" "$evidence_dir" >/dev/null 2>&1; then
  fail "evidence logs contain an unredacted secret fixture"
fi

find "$engine_clone" "$plain_clone" "$product_target" -maxdepth 4 -type f | sort > "$evidence_dir/materialized-files.txt"

cat > "$evidence_dir/SUMMARY.txt" <<SUMMARY
Devbox MVP two-device smoke passed.

Workdir: $workdir
API: $api_url

Proofs:
- Loom local-only capture/checkpoint/status works.
- Loom local filesystem remote sync and eager clone work.
- Loom sparse clone, hydrate, evict, pin, and cache status work through a local filesystem remote.
- Devbox hosted login/share/clone works eagerly through local devbox-api.
- Devbox hosted metadata/object split stores metadata packs separately from object bytes and rejects mismatched object bytes.
- Editing the source shared folder propagates to the target through sync.
- Git metadata is preserved locally and not materialized into clones.
- Generated dependency/build output directories are suppressed.
- Plain and nested folders materialize.
- Divergent remote cursor state refuses safely.
- Secret-looking files are blocked before sync and raw secret bytes are absent from remote/object cache/evidence.

Evidence logs are in this directory. Session tokens and devbox URLs are redacted.
SUMMARY

echo "mvp smoke passed"
echo "evidence=$evidence_dir"
echo "summary=$evidence_dir/SUMMARY.txt"
