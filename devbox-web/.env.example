WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
WORKOS_SIGN_OUT_REDIRECT_URI=http://localhost:3000/

# hosted-workos | local-dev-api | local-dev-fixtures
DEVBOX_DASHBOARD_DATA_MODE=local-dev-fixtures
DEVBOX_HOSTED_API_URL=
DEVBOX_HOSTED_API_SERVICE_TOKEN=
DEVBOX_LOCAL_API_URL=http://127.0.0.1:3001
DEVBOX_LOCAL_API_SESSION_TOKEN=
DEVBOX_LOCAL_API_DEVICE_ID=

# Explicit CI/local-only bypass for /auth/cli when WorkOS cannot run.
# Production must leave this unset and use WorkOS/AuthKit.
DEVBOX_LOCAL_DEV_CLI_AUTH=
DEVBOX_LOCAL_DEV_AUTH_EMAIL=local-dev@example.test

# API-side local dev-session helper gate. Keep unset in production.
DEVBOX_API_ENABLE_LOCAL_DEV_SESSION=
DEVBOX_ALLOW_NON_LOOPBACK_LOCAL_DEV_LOGIN=
